# MongoDB connection (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/family-gallery

# Secret for JWT signing (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: required on POST /api/auth/signup so only your family can register
# If unset, signup is disabled (use `npm run seed` for pre-made accounts).
FAMILY_INVITE_CODE=our-family-2026

# Optional: password used for all seeded family accounts (`npm run seed`)
# SEED_PASSWORD=family-gallery-demo
